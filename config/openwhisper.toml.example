# Optional configuration for OpenWhisper.

# Transcription backend: "whisper" (default) or "parakeet"
# transcription_backend = "whisper"

# Whisper (whisper.cpp) backend
# whisper_cli_path = "/path/to/whisper-cli"
# whisper_model_path = "/path/to/large-v3.bin"

# Parakeet (sherpa-onnx) backend
# parakeet_model_dir = "/path/to/sherpa-onnx-nemo-parakeet-tdt-0.6b-v3-int8"
# parakeet_num_threads = 4

# llama_cli_path = "/path/to/llama-cli"
# llama_model_path = "/path/to/gpt-oss-20b.bin"
# default_mode = "voice-to-text"
# default_language = "en"
# clipboard_enabled = true
# history_enabled = true
# history_dir = "./data/history"
# audio_device = "default"
# translation_target = "en"

# Pronunciation training
# pronunciation_pairs_path = "./data/pronunciation/minimal_pairs.json"
# pronunciation_paragraphs_dir = "./data/pronunciation/paragraphs"

# Auto-type (ydotool)
# Requires `ydotool` and a running `ydotoold` user-service.
# Two modes:
#   - Batch (default --auto-type): the full transcript is typed at `stop`
#     after llama formatting/translation runs. Compatible with --translate
#     and non-voice modes.
#   - Streaming (--auto-type --stream): `start` spawns a background daemon
#     that transcribes in overlapping chunks and types each piece into the
#     focused window as you speak. `stop` finalizes the tail and exits.
#     Streaming constraints:
#       * requires explicit --language (or default_language)
#       * incompatible with --translate and non-voice modes
#       * ydotool types into whatever has focus AT THE MOMENT each chunk
#         lands; no focus tracking — alt-tabbing routes text elsewhere.
# auto_type_enabled = false                # default behavior of --auto-type
# auto_type_stream_enabled = false         # default behavior of --stream
# auto_type_binary = "ydotool"             # binary name or absolute path
# auto_type_key_delay_ms = 0               # ms between keystrokes
# auto_type_key_hold_ms = 0                # ms each key is held down
# auto_type_focus_delay_ms = 0             # ms to wait before batch typing
# auto_type_chunk_seconds = 4.0            # streaming: transcription chunk size
# auto_type_overlap_seconds = 0.8          # streaming: overlap between chunks
# auto_type_finalize_timeout_s = 15        # streaming: max wait at stop
