# Optional configuration for OpenWhisper.

# Transcription backend: "whisper" (default) or "parakeet"
# transcription_backend = "whisper"

# Whisper (whisper.cpp) backend
# whisper_cli_path = "/path/to/whisper-cli"
# whisper_model_path = "/path/to/large-v3.bin"

# Parakeet (sherpa-onnx) backend
# parakeet_model_dir = "/path/to/sherpa-onnx-nemo-parakeet-tdt-0.6b-v3-int8"
# parakeet_num_threads = 4

# llama_cli_path = "/path/to/llama-cli"
# llama_model_path = "/path/to/gpt-oss-20b.bin"
# default_mode = "voice-to-text"
# default_language = "en"
# clipboard_enabled = true
# history_enabled = true
# history_dir = "./data/history"
# audio_device = "default"
# translation_target = "en"

# Pronunciation training
# pronunciation_pairs_path = "./data/pronunciation/minimal_pairs.json"
# pronunciation_paragraphs_dir = "./data/pronunciation/paragraphs"

# Auto-type (ydotool)
# Requires `ydotool` and a running `ydotoold` user-service.
# Enabling auto-type disables clipboard copy for that recording.
# Defaults type as fast as uinput allows. Raise key_delay_ms / key_hold_ms
# (e.g. to ydotool's old 20/20 defaults) if a target app drops keystrokes.
# auto_type_enabled = false                # type transcript into focused window
# auto_type_binary = "ydotool"             # binary name or absolute path
# auto_type_key_delay_ms = 0               # ms between keystrokes
# auto_type_key_hold_ms = 0                # ms each key is held down
# auto_type_focus_delay_ms = 0             # ms to wait before typing
